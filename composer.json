{
    "name": "atwx/silverstripe-frontdesk-kit",
    "description": "A frontend kit for Silverstripe framework",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "CMS"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^6.0",
        "phpoffice/phpspreadsheet": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3"
    },
    "autoload": {
        "psr-4": {
            "Atwx\\SilverstripeFrontdeskKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atwx\\SilverstripeFrontdeskKitTests\\": "tests/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
